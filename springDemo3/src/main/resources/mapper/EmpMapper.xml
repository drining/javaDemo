    <select id="getCount"
            parameterType="org.example.springdemo3.pojo.EmpPageListParams"
            resultType="java.lang.Integer">
        select count(*)
        from emp
        <include refid="empQueryConditions"/>
    </select>

    <sql id="empQueryConditions">
        <where>
            <if test="name != null and name != ''">
                and name like concat('%', #{name}, '%')
            </if>
            <if test="gender != null">
                and gender = #{gender}
            </if>
            <if test="beginDate != null">
                and entry_date <![CDATA[>=]]> #{beginDate}
            </if>
            <if test="endDate != null">
                and entry_date <![CDATA[<=]]> #{endDate}
            </if>
        </where>
    </sql>

    <select id="getEmpListByPage"
            parameterType="org.example.springdemo3.pojo.EmpPageListParams"
            resultType="org.example.springdemo3.pojo.EmpPageVO">
        select
            id,
            username,
            name,
            gender,
            phone,
            job,
            salary,
            image,
            entry_date as entryDate,
            dept_id as deptId
        from emp
        <include refid="empQueryConditions"/>
        order by update_time desc
        limit #{offset}, #{size}
    </select>

    <insert id="addEmpExprBatch">
        insert into emp_expr(emp_id, begin_date, end_date, company, job)
        values
        <foreach collection="list" item="expr" separator=",">
            (#{expr.empId}, #{expr.beginDate}, #{expr.endDate}, #{expr.company}, #{expr.job})
        </foreach>
    </insert>

